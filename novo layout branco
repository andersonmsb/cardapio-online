<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />

  <meta property="og:type" content="website">
  <meta property="og:title" content="Insano Burguer">
  <meta property="og:image" content="https://cardapio-online-orcin.vercel.app/assets/logo.png">
  <meta property="og:description" content="O melhor hamburguer artesanal">
  <meta property="og:site_name" content="InsanoBurguer">
  <meta property="og:url" content="https://cardapio-online-orcin.vercel.app">

  <title>Insano Burguer</title>

  <style>
    :root {
  --fire: #FF4500;
  --fire-dark: #CC3700;
  --fire-glow: rgba(255, 69, 0, 0.15); /* Reduzi a opacidade do brilho */
  --amber: #D97706; /* Um tom de laranja/âmbar mais escuro para melhor contraste no branco */
  
  /* MUDANÇAS PARA TEMA CLARO */
  --bg: #FFFFFF;           /* Fundo principal branco */
  --surface: #F8F8F8;      /* Superfície dos cards cinza muito claro */
  --surface2: #F0F0F0;     /* Hover e elementos secundários */
  --surface3: #E5E5E5;     /* Botões de quantidade e detalhes */
  
  --border: rgba(0,0,0,0.08);      /* Bordas escuras sutis */
  --border-hot: rgba(255, 69, 0, 0.4);
  
  --text: #1A1A1A;         /* Texto principal quase preto */
  --text-muted: #666666;   /* Texto secundário cinza */
  --text-dim: #999999;     /* Texto de endereço e rodapé */
  
  --success: #16A34A;
  --font-display: 'Anton', sans-serif;
  --font-body: 'Outfit', sans-serif;
  --radius: 18px;
  --radius-sm: 12px;
  --radius-xs: 8px;
}

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding-bottom: 100px;
      -webkit-font-smoothing: antialiased;
    }

    /* ── HERO ─────────────────────────── */
    .hero {
      position: relative;
      background: var(--bg);
      overflow: hidden;
      min-height: 340px;
      display: flex;
      align-items: flex-end;
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background-image: url('./assets/bg.png');
      background-size: cover;
      background-position: center;
      opacity: 0.18;
      filter: saturate(1.4);
    }

    /* Grain overlay */
    .hero-grain {
      position: absolute;
      inset: 0;
      opacity: 0.035;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
      background-size: 180px;
    }

    /* Bottom flame gradient */
    .hero-gradient {
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse 80% 50% at 50% 120%, rgba(255,69,0,0.15) 0%, transparent 70%),
        linear-gradient(to bottom, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0.9) 70%, var(--bg) 100%);
    }

    /* Decorative fire line */
    .hero-line {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg, transparent, var(--fire), var(--amber), var(--fire), transparent);
      opacity: 0.7;
    }

    .hero-content {
      position: relative;
      z-index: 2;
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 48px 20px 40px;
      text-align: center;
    }

    .logo-ring {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      position: relative;
      margin-bottom: 18px;
    }

    .logo-ring::before {
      content: '';
      position: absolute;
      inset: -3px;
      border-radius: 50%;
      background: conic-gradient(var(--fire), var(--amber), var(--fire));
      animation: spin-ring 4s linear infinite;
    }

    .logo-ring::after {
      content: '';
      position: absolute;
      inset: 0;
      border-radius: 50%;
      background: var(--bg);
      margin: -1px;
    }

    @keyframes spin-ring {
      to { transform: rotate(360deg); }
    }

    .logo-ring img {
      width: 82px;
      height: 82px;
      border-radius: 50%;
      object-fit: cover;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      z-index: 1;
    }

    .hero-name {
      font-family: var(--font-display);
      font-size: clamp(3rem, 12vw, 6rem);
      letter-spacing: 0.06em;
      color: var(--text);
      line-height: 0.9;
      text-transform: uppercase;
    }

    .hero-name span {
      color: var(--fire);
      display: block;
      font-size: clamp(2.2rem, 9vw, 4.5rem);
      letter-spacing: 0.14em;
    }

    .hero-tagline {
      font-size: 0.78rem;
      color: var(--text-muted);
      margin-top: 10px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 500;
    }

    .status-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 18px;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 600;
      margin-top: 16px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      backdrop-filter: blur(12px);
    }

    .status-badge.open {
      background: rgba(34,197,94,0.12);
      color: #4ade80;
      border: 1px solid rgba(34,197,94,0.25);
    }

    .status-badge.closed {
      background: rgba(255,69,0,0.1);
      color: #ff7a5a;
      border: 1px solid rgba(255,69,0,0.25);
    }

    .status-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
    }

    .status-badge.open .status-dot {
      background: #22c55e;
      box-shadow: 0 0 6px #22c55e;
      animation: pulse-dot 2s infinite;
    }

    .status-badge.closed .status-dot { background: var(--fire); }

    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }

    .hero-address {
      font-size: 0.73rem;
      color: var(--text-dim);
      margin-top: 8px;
      letter-spacing: 0.04em;
    }

    /* ── SECTION NAV ─────────────────── */
    .section-nav {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(255,255,255,0.85); /* Alterado de 12,12,12 para branco */
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
      display: flex;
      overflow-x: auto;
      scrollbar-width: none;
      gap: 4px;
      padding: 10px 16px;
    }

    .section-nav::-webkit-scrollbar { display: none; }

    .tab-btn {
      flex: 0 0 auto;
      padding: 9px 20px;
      background: none;
      border: 1px solid transparent;
      border-radius: 100px;
      font-family: var(--font-body);
      font-size: 0.82rem;
      font-weight: 600;
      color: var(--text-muted);
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
      letter-spacing: 0.02em;
    }

    .tab-btn:hover {
      color: var(--text);
      background: var(--surface2);
    }

    .tab-btn.active {
      color: var(--bg);
      background: var(--fire);
      border-color: var(--fire);
      box-shadow: 0 0 18px var(--fire-glow);
    }

    /* ── SECTION HEADERS ─────────────── */
    .section-header {
      padding: 36px 20px 20px;
      max-width: 920px;
      margin: 0 auto;
    }

    .section-eyebrow {
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--fire);
      margin-bottom: 8px;
    }

    .section-title {
      font-family: var(--font-display);
      font-size: clamp(2rem, 8vw, 3.2rem);
      letter-spacing: 0.05em;
      color: var(--text);
      line-height: 0.95;
      text-transform: uppercase;
    }

    .section-title span { color: var(--fire); }

    .section-subtitle {
      font-size: 0.82rem;
      color: var(--text-muted);
      margin-top: 8px;
      font-weight: 400;
    }

    /* ── PRODUCT GRID ─────────────────── */
    .products-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 14px;
      padding: 0 16px 8px;
      max-width: 920px;
      margin: 0 auto;
    }

    @media (min-width: 540px) {
      .products-grid { grid-template-columns: 1fr 1fr; }
    }

    @media (min-width: 900px) {
      .products-grid { grid-template-columns: 1fr 1fr 1fr; padding: 0 20px 8px; }
    }

    /* ── PRODUCT CARD ─────────────────── */
    .product-card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      overflow: hidden;
      transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
      display: flex;
      flex-direction: column;
      position: relative;
    }

    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: 0 16px 48px rgba(0,0,0,0.5), 0 0 0 1px var(--border-hot);
      border-color: var(--border-hot);
    }

    .product-img-wrap {
      width: 100%;
      height: 170px;
      overflow: hidden;
      background: var(--surface2);
      position: relative;
    }

    .product-img-wrap::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      height: 50px;
      background: linear-gradient(to bottom, transparent, var(--surface));
    }

    .product-img-wrap img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .product-card:hover .product-img-wrap img { transform: scale(1.08); }

    .product-body {
      padding: 14px 16px 16px;
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .product-badge {
      display: inline-block;
      font-size: 0.58rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--fire);
      background: rgba(255,69,0,0.1);
      border: 1px solid rgba(255,69,0,0.2);
      border-radius: 4px;
      padding: 2px 8px;
      width: fit-content;
      margin-bottom: 7px;
    }

    .product-name {
      font-size: 1rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: 4px;
    }

    .product-desc {
      font-size: 0.75rem;
      color: var(--text-muted);
      line-height: 1.5;
      font-weight: 400;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .product-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 14px;
      gap: 10px;
    }

    .product-price {
      font-family: var(--font-display);
      font-size: 1.4rem;
      color: var(--amber);
      letter-spacing: 0.02em;
      line-height: 1;
    }

    .product-price small {
      font-family: var(--font-body);
      font-size: 0.68rem;
      font-weight: 600;
      color: var(--text-muted);
      margin-right: 1px;
      vertical-align: middle;
    }

    .add-btn {
      display: flex;
      align-items: center;
      gap: 6px;
      background: var(--fire);
      color: #fff;
      border: none;
      border-radius: 100px;
      padding: 9px 16px;
      font-family: var(--font-body);
      font-size: 0.78rem;
      font-weight: 700;
      cursor: pointer;
      transition: all 0.18s ease;
      white-space: nowrap;
      letter-spacing: 0.02em;
    }

    .add-btn:hover {
      background: var(--fire-dark);
      box-shadow: 0 0 20px var(--fire-glow);
      transform: scale(1.04);
    }

    .add-btn:active { transform: scale(0.96); }

    /* ── DRINKS SECTION ─────────────── */
    .drinks-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
      padding: 0 16px 8px;
      max-width: 920px;
      margin: 0 auto;
    }

    @media (min-width: 640px) {
      .drinks-grid { grid-template-columns: repeat(3, 1fr); gap: 14px; padding: 0 20px 8px; }
    }

    @media (min-width: 900px) {
      .drinks-grid { grid-template-columns: repeat(4, 1fr); }
    }

    .drink-card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 20px 14px 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      text-align: center;
      transition: all 0.25s ease;
      cursor: default;
    }

    .drink-card:hover {
      transform: translateY(-4px);
      border-color: var(--border-hot);
      box-shadow: 0 12px 40px rgba(0,0,0,0.4);
    }

    .drink-emoji-wrap {
      width: 70px;
      height: 70px;
      border-radius: 50%;
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      transition: transform 0.3s ease;
    }

    .drink-card:hover .drink-emoji-wrap { transform: scale(1.1) rotate(-5deg); }

    .drink-img {
      width: 60px;
      height: 60px;
      object-fit: contain;
    }

    .drink-emoji {
      font-size: 2.2rem;
    }

    .drink-name {
      font-size: 0.85rem;
      font-weight: 700;
      color: var(--text);
      line-height: 1.2;
    }

    .drink-price {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--amber);
      letter-spacing: 0.02em;
    }

    .drink-add-btn {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      background: var(--surface3);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 8px 12px;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
    }

    .drink-add-btn:hover {
      background: var(--fire);
      border-color: var(--fire);
      box-shadow: 0 0 16px var(--fire-glow);
    }

    .drink-add-btn:active { transform: scale(0.97); }

    /* ── EXTRAS ─────────────────────── */
    .extras-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 0 16px 8px;
      max-width: 920px;
      margin: 0 auto;
    }

    @media (min-width: 640px) {
      .extras-grid { grid-template-columns: 1fr 1fr; gap: 14px; padding: 0 20px 8px; }
    }

    .extra-card {
      background: var(--surface);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      padding: 16px 18px;
      gap: 16px;
      transition: all 0.25s ease;
    }

    .extra-card:hover {
      transform: translateY(-2px);
      border-color: var(--border-hot);
      box-shadow: 0 8px 32px rgba(0,0,0,0.35);
    }

    .extra-emoji-wrap {
      width: 52px;
      height: 52px;
      border-radius: var(--radius-xs);
      background: var(--surface2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.8rem;
      flex-shrink: 0;
    }

    .extra-info { flex: 1; }

    .extra-name {
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--text);
    }

    .extra-desc {
      font-size: 0.73rem;
      color: var(--text-muted);
      margin-top: 3px;
      font-weight: 400;
    }

    .extra-footer {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 8px;
    }

    .extra-price {
      font-family: var(--font-display);
      font-size: 1.2rem;
      color: var(--amber);
      letter-spacing: 0.02em;
    }

    .extra-btn {
      background: var(--surface3);
      color: var(--text);
      border: 1px solid var(--border);
      border-radius: 100px;
      padding: 7px 16px;
      font-family: var(--font-body);
      font-size: 0.75rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s ease;
      white-space: nowrap;
    }

    .extra-btn:hover {
      background: var(--fire);
      border-color: var(--fire);
      box-shadow: 0 0 16px var(--fire-glow);
    }

    /* ── SECTION SEPARATOR ────────── */
    .section-sep {
      height: 1px;
      background: var(--border);
      margin: 36px 20px 0;
      max-width: 880px;
      margin-left: auto;
      margin-right: auto;
    }

    /* ── CART FAB ──────────────────── */
    .cart-fab {
      position: fixed;
      bottom: 22px;
      left: 50%;
      transform: translateX(-50%);
      z-index: 200;
      background: var(--fire);
      color: #fff;
      border: none;
      border-radius: 100px;
      padding: 15px 30px;
      display: flex;
      align-items: center;
      gap: 12px;
      font-family: var(--font-body);
      font-size: 0.92rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 8px 32px var(--fire-glow), 0 2px 8px rgba(0,0,0,0.4);
      transition: all 0.22s ease;
      white-space: nowrap;
      min-width: 220px;
      justify-content: center;
      letter-spacing: 0.02em;
    }

    .cart-fab:hover {
      transform: translateX(-50%) translateY(-3px) scale(1.03);
      box-shadow: 0 14px 40px var(--fire-glow), 0 4px 16px rgba(0,0,0,0.4);
    }

    .cart-fab:active { transform: translateX(-50%) scale(0.97); }

    .cart-count-badge {
      background: #fff;
      color: var(--fire);
      border-radius: 100px;
      width: 24px;
      height: 24px;
      font-size: 0.72rem;
      font-weight: 800;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* ── MODAL ─────────────────────── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.75);
      backdrop-filter: blur(8px);
      z-index: 300;
      display: none;
      align-items: flex-end;
      justify-content: center;
    }

    .modal-overlay.active { display: flex; }

    @media (min-width: 640px) {
      .modal-overlay { align-items: center; padding: 24px; }
    }

    .modal-sheet {
      background: var(--surface);
      width: 100%;
      max-width: 520px;
      border-radius: 24px 24px 0 0;
      padding: 0;
      max-height: 92vh;
      display: flex;
      flex-direction: column;
      animation: slideUp 0.32s cubic-bezier(0.32, 0.72, 0, 1);
      overflow: hidden;
      border: 1px solid var(--border);
      border-bottom: none;
    }

    @media (min-width: 640px) {
      .modal-sheet { border-radius: 24px; border-bottom: 1px solid var(--border); }
    }

    @keyframes slideUp {
      from { transform: translateY(60px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }

    .modal-handle {
      width: 36px;
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      margin: 14px auto 0;
      flex-shrink: 0;
    }

    .modal-header {
      padding: 16px 22px 15px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-shrink: 0;
    }

    .modal-title {
      font-family: var(--font-display);
      font-size: 1.6rem;
      letter-spacing: 0.06em;
      color: var(--text);
      text-transform: uppercase;
    }

    .modal-close {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--surface2);
      border: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--text-muted);
      font-size: 0.85rem;
      transition: all 0.18s;
    }

    .modal-close:hover { background: var(--surface3); color: var(--text); }

    .modal-body {
      flex: 1;
      overflow-y: auto;
      padding: 16px 22px;
      scrollbar-width: thin;
      scrollbar-color: var(--surface3) transparent;
    }

    /* ── CART ITEMS ────────────────── */
    .cart-empty {
      text-align: center;
      padding: 48px 20px;
      color: var(--text-muted);
    }

    .cart-empty i {
      font-size: 2.8rem;
      margin-bottom: 14px;
      opacity: 0.2;
      display: block;
    }

    .cart-empty p { font-size: 0.9rem; }

    .cart-item {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid var(--border);
    }

    .cart-item:last-child { border-bottom: none; }

    .cart-item-info { flex: 1; min-width: 0; }

    .cart-item-name {
      font-size: 0.9rem;
      font-weight: 700;
      color: var(--text);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
