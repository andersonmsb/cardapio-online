<script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
<script>
// ── DOM REFS ─────────────────────────────────
const menu = document.getElementById("menu")
const cartBtn = document.getElementById("cart-btn")
const cartModal = document.getElementById("cart-modal")
const cartItemsContainer = document.getElementById("cart-items")
const cartTotal = document.getElementById("cart-total")
const checkoutBtn = document.getElementById("checkout-btn")
const closeModalBtn = document.getElementById("close-modal-btn")
const cartCounter = document.getElementById("cart-count")
const addressInput = document.getElementById("address")
const addressWarn = document.getElementById("address-warn")

let cart = []

// ── TABS ─────────────────────────────────────
document.querySelectorAll('.tab-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'))
    btn.classList.add('active')
    const target = document.getElementById(btn.dataset.target)
    if (target) {
      const offset = 66
      const top = target.getBoundingClientRect().top + window.scrollY - offset
      window.scrollTo({ top, behavior: 'smooth' })
    }
  })
})

// ── MODAL OPEN ───────────────────────────────
cartBtn.addEventListener("click", function(){
  updateCartModal()
  cartModal.classList.add("active")
  document.body.style.overflow = "hidden"
})

// ── MODAL CLOSE ──────────────────────────────
cartModal.addEventListener("click", function(event){
  if(event.target === cartModal){ closeModal() }
})

closeModalBtn.addEventListener("click", closeModal)

function closeModal(){
  cartModal.classList.remove("active")
  document.body.style.overflow = ""
}

// ── ADD TO CART ──────────────────────────────
menu.addEventListener("click", function(event){
  const parentButton = event.target.closest(".add-to-cart-btn")
  if(parentButton){
    const name = parentButton.getAttribute("data-name")
    const price = parseFloat(parentButton.getAttribute("data-price"))
    addToCart(name, price)
  }
})

function addToCart(name, price){
  const existingItem = cart.find(item => item.name === name)
  if(existingItem){
    existingItem.qtd += 1
  } else {
    cart.push({ name, price, qtd: 1 })
  }
  updateCartModal()
  showToast("✓ " + name + " adicionado!", "#22C55E")
}

function showToast(text, bg){
  Toastify({
    text,
    duration: 1800,
    close: false,
    gravity: "top",
    position: "right",
    stopOnFocus: false,
    style: { background: bg, borderRadius: "100px", fontSize: "0.82rem", fontWeight: "700", padding: "10px 20px", fontFamily: "'Outfit', sans-serif" },
  }).showToast()
}

// ── UPDATE MODAL ─────────────────────────────
function updateCartModal(){
  cartItemsContainer.innerHTML = ""
  let total = 0

  if(cart.length === 0){
    cartItemsContainer.innerHTML = `
      <div class="cart-empty">
        <i class="fa fa-shopping-bag"></i>
        <p>Seu carrinho está vazio</p>
        <p style="margin-top:8px;font-size:0.78rem;color:var(--text-dim)">Adicione itens do cardápio para começar 🍔</p>
      </div>`
    cartCounter.textContent = "0"
    cartTotal.textContent = "R$ 0,00"
    return
  }

  cart.forEach(item => {
    const el = document.createElement("div")
    el.classList.add("cart-item")
    el.innerHTML = `
      <div class="cart-item-info">
        <p class="cart-item-name">${item.name}</p>
        <p class="cart-item-price">R$ ${item.price.toFixed(2).replace('.',',')} · un</p>
      </div>
      <div class="cart-item-controls">
        <button class="qty-btn minus remove-cart-btn" data-name="${item.name}" title="Remover um">−</button>
        <span class="qty-val">${item.qtd}</span>
        <button class="qty-btn plus add-one-btn" data-name="${item.name}" data-price="${item.price}" title="Adicionar um">+</button>
      </div>
      <div class="cart-item-total">R$ ${(item.price * item.qtd).toFixed(2).replace('.',',')}</div>
    `
    total += item.price * item.qtd
    cartItemsContainer.appendChild(el)
  })

  cartTotal.textContent = total.toLocaleString("pt-BR", { style: "currency", currency: "BRL" })
  cartCounter.textContent = cart.reduce((sum, i) => sum + i.qtd, 0)
}

// ── REMOVE / ADD ONE ─────────────────────────
cartItemsContainer.addEventListener("click", function(event){
  const removeBtn = event.target.closest(".remove-cart-btn")
  const addOneBtn = event.target.closest(".add-one-btn")
  if(removeBtn){ removeItemCart(removeBtn.getAttribute("data-name")) }
  if(addOneBtn){
    const name = addOneBtn.getAttribute("data-name")
    const price = parseFloat(addOneBtn.getAttribute("data-price"))
    addToCart(name, price)
  }
})

function removeItemCart(name){
  const index = cart.findIndex(item => item.name === name)
  if(index !== -1){
    if(cart[index].qtd > 1){ cart[index].qtd -= 1 }
    else { cart.splice(index, 1) }
    updateCartModal()
  }
}

// ── ADDRESS VALIDATION ───────────────────────
addressInput.addEventListener("input", function(){
  if(this.value !== ""){
    this.classList.remove("error")
    addressWarn.classList.remove("show")
  }
})

// ── CHECKOUT ─────────────────────────────────
checkoutBtn.addEventListener("click", function(){
  if(!checkOpen()){
    showToast("😴 Restaurante fechado no momento", "#ef4444")
    return
  }
  if(cart.length === 0){
    showToast("Carrinho vazio!", "#ef4444")
    return
  }
  if(addressInput.value.trim() === ""){
    addressWarn.classList.add("show")
    addressInput.classList.add("error")
    addressInput.focus()
    return
  }

  const cartItems = cart.map(item =>
    `▸ ${item.name} x${item.qtd} — R$${(item.price * item.qtd).toFixed(2)}`
  ).join("\n")

  const total = cart.reduce((s, i) => s + i.price * i.qtd, 0)
  const message = encodeURIComponent(
    `🍔 *Pedido - Insano Burguer*\n\n${cartItems}\n\n💰 *Total: ${total.toLocaleString("pt-BR",{style:"currency",currency:"BRL"})}*\n\n📍 Endereço: ${addressInput.value.trim()}`
  )
  const phone = "18981312797"
  window.open(`https://wa.me/${phone}?text=${message}`, "_blank")

  cart = []
  updateCartModal()
  closeModal()
})

// ── STATUS CHECK ─────────────────────────────
function checkOpen(){
  const hora = new Date().getHours()
  return hora >= 18 && hora < 22
}

const statusBadge = document.getElementById("date-span")
const isOpen = checkOpen()
if(isOpen){
  statusBadge.classList.add("open")
  statusBadge.classList.remove("closed")
  document.getElementById("status-text").textContent = "Aberto agora · até 22:00"
} else {
  statusBadge.classList.add("closed")
  statusBadge.classList.remove("open")
  document.getElementById("status-text").textContent = "Fechado · Abre às 18:00"
}

// ── SCROLL REVEAL ────────────────────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add("visible") })
}, { threshold: 0.08 })

document.querySelectorAll(".fade-in").forEach(el => observer.observe(el))

// ── SWIPE DOWN TO CLOSE MODAL ────────────────
let startY = 0
const sheet = document.querySelector(".modal-sheet")

sheet.addEventListener("touchstart", e => { startY = e.touches[0].clientY }, { passive: true })
sheet.addEventListener("touchend", e => {
  if(e.changedTouches[0].clientY - startY > 80) closeModal()
}, { passive: true })
</script>

</body>
